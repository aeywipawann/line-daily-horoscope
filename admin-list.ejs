<!doctype html>
<html lang="th">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>จัดการคำทำนาย</title>
    <style>
      body { font-family:system-ui,sans-serif; margin:0; background:#f7f5fa; color:#282331 }
      header { background:#5b3f8c; color:white; padding:18px 4vw; display:flex; align-items:center; justify-content:space-between }
      main { max-width:1100px; margin:24px auto; padding:0 18px }
      .toolbar { display:flex; gap:10px; flex-wrap:wrap; margin-bottom:20px } a,button { border:0; border-radius:8px; padding:9px 13px; text-decoration:none; cursor:pointer }
      .primary { background:#5b3f8c; color:white } .muted { background:#e9e2f3; color:#493270 }
      table { width:100%; border-collapse:collapse; background:white; border-radius:12px; overflow:hidden }
      th,td { padding:12px; text-align:left; border-bottom:1px solid #eee } th { background:#eee8f6 }
      .published { color:#147542; font-weight:700 } .draft { color:#956413; font-weight:700 }
      form { display:inline } input[type=date] { padding:8px }
      @media(max-width:700px){ table,thead,tbody,tr,td { display:block } th { display:none } td { border:0 } tr { padding:12px; border-bottom:1px solid #ddd } }
    </style>
  </head>
  <body>
    <header>
      <strong>Horoscope Admin</strong>
      <form method="post" action="/admin/logout">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <button type="submit">ออกจากระบบ</button>
      </form>
    </header>
    <main>
      <div class="toolbar">
        <a class="primary" href="/admin/horoscopes/new">+ เพิ่มคำทำนาย</a>
        <form method="get" action="/admin">
          <input type="date" name="date" value="<%= date %>">
          <button class="muted" type="submit">กรองวันที่</button>
        </form>
        <a class="muted" href="/admin">ดูทั้งหมด</a>
      </div>
      <table>
        <thead><tr><th>วันที่</th><th>ราศี</th><th>สถานะ</th><th>จัดการ</th></tr></thead>
        <tbody>
          <% horoscopes.forEach(function(item) { %>
            <tr>
              <td><%= item.horoscopeDate %></td>
              <td>ราศี<%= zodiacThai[item.zodiacSign] %></td>
              <td class="<%= item.status %>"><%= item.status === "published" ? "เผยแพร่แล้ว" : "ฉบับร่าง" %></td>
              <td>
                <a class="muted" href="/admin/horoscopes/<%= item.id %>/edit">แก้ไข</a>
                <form method="post" action="/admin/horoscopes/<%= item.id %>/status">
                  <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                  <input type="hidden" name="status" value="<%= item.status === "published" ? "draft" : "published" %>">
                  <button class="primary" type="submit"><%= item.status === "published" ? "กลับเป็น Draft" : "Publish" %></button>
                </form>
              </td>
            </tr>
          <% }) %>
          <% if (!horoscopes.length) { %><tr><td colspan="4">ยังไม่มีคำทำนาย</td></tr><% } %>
        </tbody>
      </table>
    </main>
  </body>
</html>
