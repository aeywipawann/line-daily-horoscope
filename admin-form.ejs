<!doctype html>
<html lang="th">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title><%= horoscope && horoscope.id ? "แก้ไข" : "เพิ่ม" %>คำทำนาย</title>
    <style>
      body { font-family:system-ui,sans-serif; background:#f7f5fa; color:#282331; margin:0 }
      main { max-width:820px; margin:30px auto; background:white; padding:28px; border-radius:14px }
      .grid { display:grid; grid-template-columns:1fr 1fr; gap:16px } label { display:block; font-weight:700; margin-bottom:6px }
      input,select,textarea { width:100%; box-sizing:border-box; padding:10px; border:1px solid #ccc; border-radius:8px }
      textarea { min-height:90px; resize:vertical } .full { grid-column:1/-1 }
      button,a { padding:11px 16px; border:0; border-radius:8px; text-decoration:none }
      button { background:#5b3f8c; color:white; font-weight:700 } a { background:#e9e2f3; color:#493270 }
      .actions { display:flex; gap:10px; margin-top:22px } .error { color:#9d2535 }
      @media(max-width:650px){ .grid { grid-template-columns:1fr } .full { grid-column:auto } }
    </style>
  </head>
  <body>
    <main>
      <h1><%= horoscope && horoscope.id ? "แก้ไข" : "เพิ่ม" %>คำทำนาย</h1>
      <% if (error) { %><p class="error"><%= error %></p><% } %>
      <form method="post" action="/admin/horoscopes/save">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <div class="grid">
          <div>
            <label for="horoscopeDate">วันที่</label>
            <input id="horoscopeDate" type="date" name="horoscopeDate" value="<%= horoscope ? horoscope.horoscopeDate : "" %>" required>
          </div>
          <div>
            <label for="zodiacSign">ราศี</label>
            <select id="zodiacSign" name="zodiacSign" required>
              <% zodiacKeys.forEach(function(key) { %>
                <option value="<%= key %>" <%= horoscope && horoscope.zodiacSign === key ? "selected" : "" %>>ราศี<%= zodiacThai[key] %></option>
              <% }) %>
            </select>
          </div>
          <% [
            ["overview","ภาพรวม"],["career","การงาน"],["finance","การเงิน"],
            ["love","ความรัก"],["health","สุขภาพทั่วไป"],["advice","คำแนะนำ"]
          ].forEach(function(field) { %>
            <div class="full">
              <label for="<%= field[0] %>"><%= field[1] %></label>
              <textarea id="<%= field[0] %>" name="<%= field[0] %>" maxlength="800" required><%= horoscope ? horoscope[field[0]] : "" %></textarea>
            </div>
          <% }) %>
          <div>
            <label for="luckyColor">สีมงคล</label>
            <input id="luckyColor" name="luckyColor" maxlength="100" value="<%= horoscope ? horoscope.luckyColor : "" %>" required>
          </div>
          <div>
            <label for="luckyNumber">เลขนำโชค</label>
            <input id="luckyNumber" name="luckyNumber" maxlength="100" value="<%= horoscope ? horoscope.luckyNumber : "" %>" required>
          </div>
          <div>
            <label for="status">สถานะ</label>
            <select id="status" name="status">
              <option value="draft" <%= !horoscope || horoscope.status === "draft" ? "selected" : "" %>>Draft</option>
              <option value="published" <%= horoscope && horoscope.status === "published" ? "selected" : "" %>>Published</option>
            </select>
          </div>
        </div>
        <div class="actions"><button type="submit">บันทึก</button><a href="/admin">ยกเลิก</a></div>
      </form>
    </main>
  </body>
</html>
