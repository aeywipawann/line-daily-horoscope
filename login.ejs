<!doctype html>
<html lang="th">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>เข้าสู่ระบบผู้ดูแล</title>
    <style>
      body { font-family: system-ui, sans-serif; background:#f4f0fa; margin:0; color:#292334 }
      main { max-width:420px; margin:10vh auto; background:white; padding:32px; border-radius:16px; box-shadow:0 8px 30px #39285c20 }
      label { display:block; margin:16px 0 6px } input { width:100%; padding:12px; box-sizing:border-box; border:1px solid #ccc; border-radius:8px }
      button { width:100%; margin-top:22px; padding:12px; background:#5b3f8c; color:white; border:0; border-radius:8px; font-weight:700 }
      .error { background:#ffe8eb; color:#8a2432; padding:10px; border-radius:8px }
    </style>
  </head>
  <body>
    <main>
      <h1>Horoscope Admin</h1>
      <% if (error) { %><p class="error"><%= error %></p><% } %>
      <form method="post" action="/admin/login">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <label for="username">ชื่อผู้ใช้</label>
        <input id="username" name="username" autocomplete="username" required>
        <label for="password">รหัสผ่าน</label>
        <input id="password" type="password" name="password" autocomplete="current-password" required>
        <button type="submit">เข้าสู่ระบบ</button>
      </form>
    </main>
  </body>
</html>
