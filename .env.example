NODE_ENV=development
PORT=3000
APP_BASE_URL=https://your-service.onrender.com

# LINE Developers Console > Messaging API
LINE_CHANNEL_SECRET=replace_with_line_channel_secret
LINE_CHANNEL_ACCESS_TOKEN=replace_with_long_lived_channel_access_token

# PostgreSQL / Supabase connection string. SSL is enabled in production.
DATABASE_URL=postgresql://user:password@host:5432/line_horoscope
DATABASE_SSL=false

# Generate at least 32 random bytes, for example: openssl rand -base64 48
SESSION_SECRET=replace_with_a_long_random_value

# Generate with: npm run admin:hash-password -- "your strong password"
ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=replace_with_bcrypt_hash

# Per-user bot throttling
USER_RATE_LIMIT_WINDOW_SECONDS=20
USER_RATE_LIMIT_MAX=5
